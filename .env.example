# API listen (inside Docker the service listens on 3000; map host port via HOST_PORT in compose).
PORT=3000
HOST=0.0.0.0

# Published port on the host (used by docker-compose.yml).
HOST_PORT=3000

# SQLite database file path. In Compose, /data is mounted from AGENT_DATA_HOST_PATH.
SQLITE_PATH=/data/agent.sqlite

# Workspace storage. Host paths are resolved by setup scripts; containers use the stable /workspace path.
# Defaults:
#   Linux: ~/.agent-platform
#   macOS: ~/Library/Application Support/AgentPlatform
#   Windows: %LOCALAPPDATA%\AgentPlatform
# Local development fallback used by Makefile/docker-compose:
AGENT_PLATFORM_HOME=./.agent-platform
AGENT_WORKSPACE_HOST_PATH=./.agent-platform/workspaces/default
AGENT_WORKSPACE_CONTAINER_PATH=/workspace
AGENT_DATA_HOST_PATH=./.agent-platform/data

# Base64-encoded 32-byte key for AES-256-GCM secret storage.
# Required to create/use model configs with stored API keys.
# Generate: openssl rand -base64 32
# docker-compose.yml includes a dev-only default so `make up` works without this set.
# Set your own key here for production — never share the dev default key across environments.
SECRETS_MASTER_KEY=

# API OpenAI key for POST /v1/chat (harness). Prefer this over OPENAI_API_KEY.
AGENT_OPENAI_API_KEY=

# If you only have OPENAI_API_KEY in your shell profile, either copy it here as AGENT_OPENAI_API_KEY,
# set OPENAI_ALLOW_LEGACY_ENV=1, or use `make api` / `make up` which copies OPENAI_API_KEY for local runs.

# Optional: allow legacy OPENAI_API_KEY when AGENT_OPENAI_API_KEY is unset (not recommended for production).
# OPENAI_ALLOW_LEGACY_ENV=1
