# API listen (inside Docker the service listens on 3000; map host port via HOST_PORT in compose).
PORT=3000
HOST=0.0.0.0

# Published port on the host (used by docker-compose.yml).
HOST_PORT=3000

# SQLite database file path. In Compose, the default mounts a named volume at /data.
SQLITE_PATH=/data/agent.sqlite

# Optional: host directory to bind-mount for future filesystem MCP workspace (see docker-compose.yml).
# MCP_HOST_WORKSPACE=./mcp-workspace
