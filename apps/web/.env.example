# Optional explicit key for legacy/manual flows. Normal chat execution resolves
# provider defaults on the API host from saved model configs or API env.
NEXT_OPENAI_API_KEY=
#
# Same as API root `.env` — optional here so one file can drive local harness chat:
# AGENT_OPENAI_API_KEY=
#
# Legacy fallback is blocked by default to prevent accidental inherited shell exports.
# Set OPENAI_ALLOW_LEGACY_ENV=1 only if you intentionally want to use OPENAI_API_KEY.
# OPENAI_API_KEY=

# Default model sent by the chat UI. NEXT_PUBLIC_ prefix makes it available client-side.
# Falls back to 'gpt-4o-mini' when unset.
NEXT_PUBLIC_DEFAULT_MODEL=gpt-4o-mini

# Target for the Next.js BFF proxy `apps/web/app/api/v1/*` (Express API, default port 3000).
API_PROXY_URL=http://127.0.0.1:3000
#
# Max wait (ms) for /v1/chat to send response headers when proxying from /api/chat (default 90000).
# CHAT_PROXY_HEADER_TIMEOUT_MS=120000

# IDE terminal: WebSocket to API PTY (default ws://<host>:3000/ws/terminal). Override if API is elsewhere.
# If you use SSH/Cursor port forwarding: forward the API port (3000) as well as the web port, or the browser cannot reach the PTY WebSocket while /health may still work from curl on the server.
# NEXT_PUBLIC_TERMINAL_WS_URL=ws://127.0.0.1:3000/ws/terminal
# NEXT_PUBLIC_API_PORT=3000
# Prefer IPv4 for WebSocket when page is opened as localhost (avoids some ws://localhost failures):
# NEXT_PUBLIC_API_HOST=127.0.0.1
#
# API: default PTY cwd when client sends no ?cwd= is $HOME; optional TERMINAL_CWD falls back before home.
# TERMINAL_CWD=
