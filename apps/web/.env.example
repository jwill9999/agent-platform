# Preferred server-side key for `/api/chat` (scoped to Next.js server process).
NEXT_OPENAI_API_KEY=
#
# Legacy fallback is blocked by default to prevent accidental inherited shell exports.
# Set OPENAI_ALLOW_LEGACY_ENV=1 only if you intentionally want to use OPENAI_API_KEY.
# OPENAI_API_KEY=

# Target for the Next.js BFF proxy `apps/web/app/api/v1/*` (Express API, default port 3000).
API_PROXY_URL=http://127.0.0.1:3000
