{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash ./.github/hooks/inject-docs-policy.sh",
        "timeout": 10
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash ./.github/hooks/inject-docs-policy.sh",
        "timeout": 10
      }
    ]
  }
}
