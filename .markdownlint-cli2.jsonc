// markdownlint-cli2 configuration. See https://github.com/DavidAnson/markdownlint-cli2
{
    "config": {
        "default": true,
        "MD003": {
            "style": "atx"
        },
        "MD004": {
            "style": "dash"
        },
        "MD007": {
            "indent": 2
        },
        "MD013": false,
        "MD024": {
            "siblings_only": true
        },
        "MD029": false,
        "MD033": false,
        "MD034": false,
        "MD036": false,
        "MD040": false,
        "MD041": false,
        "MD046": {
            "style": "fenced"
        },
        "MD049": {
            "style": "underscore"
        },
        "MD050": {
            "style": "asterisk"
        }
    },
    "ignores": [
