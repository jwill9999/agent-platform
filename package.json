{
  "name": "agent-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm --filter @agent-platform/contracts build && pnpm --filter @agent-platform/agent-validation build && pnpm --filter @agent-platform/db build && pnpm --filter @agent-platform/mcp-adapter build && pnpm --filter @agent-platform/harness build && pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"apps/**/*.{ts,json,md}\" \"packages/**/*.{ts,json,md}\" \"*.{js,json}\" \"README.md\" \"CONTRIBUTING.md\"",
    "format:check": "prettier --check \"apps/**/*.{ts,json,md}\" \"packages/**/*.{ts,json,md}\" \"*.{js,json}\" \"README.md\" \"CONTRIBUTING.md\"",
    "seed": "pnpm --filter @agent-platform/db run seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
